TELEGRAM_TOKEN=PASTE_TELEGRAM_TOKEN_HERE

OPENROUTER_API_KEY=PASTE_OPENROUTER_KEY_HERE
GROQ_API_KEY=PASTE_GROQ_KEY_HERE
OPENAI_API_KEY=PASTE_OPENAI_KEY_HERE

# Gemini API. Реальный ключ хранить только в /root/bot/.env, не в GitHub.
GEMINI_API_KEY=PASTE_GEMINI_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

ADMIN_IDS=123456789

DATABASE_PATH=bot.db
PERSONALITY_PATH=personality.txt

OPENROUTER_DEEPSEEK_MODEL=deepseek/deepseek-chat
OPENROUTER_AUTO_MODEL=openrouter/auto
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4.1-mini

DEFAULT_HISTORY_LIMIT=18
DEFAULT_MEDIA_CHANCE=10
